# ============================================================
#  Firebase — Configuración del panel admin (/admin)
#  Copiá este archivo como ".env" y completá con los datos de
#  tu proyecto Firebase (Configuración del proyecto → Tus apps → Web).
#  IMPORTANTE: estas mismas variables hay que cargarlas en Vercel
#  (Project → Settings → Environment Variables).
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: ID del Meta Pixel (si lo cambiás)
# VITE_META_PIXEL_ID=
