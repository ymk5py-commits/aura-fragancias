# ============================================================
#  Äura Fragancias — Variables de entorno
#  Copiá este archivo como ".env" y completá los valores.
#  IMPORTANTE: TODAS van también en Vercel -> Project -> Settings ->
#  Environment Variables (Production + Preview).
#  Las NEXT_PUBLIC_* son públicas por diseño (van al navegador).
#  META_CAPI_TOKEN es SECRETO: nunca le pongas NEXT_PUBLIC_.
# ============================================================

# --- Firebase (panel /admin y datos SSR) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Meta Ads (Pixel + Conversions API) ---
# Pixel activo de Aura: 1238570975103624 (ya viene por defecto en el codigo)
NEXT_PUBLIC_META_PIXEL_ID=1238570975103624
# Token de la Conversions API (Events Manager -> Conversions API -> Generar token).
# SECRETO - sin NEXT_PUBLIC. Rotalo si lo expones.
META_CAPI_TOKEN=
# Opcional: codigo de Test Events mientras validas.
META_TEST_EVENT_CODE=

# --- Google (GA4 + Google Ads) ---
# GA4: Admin -> Flujos de datos -> ID de medicion (empieza con G-)
NEXT_PUBLIC_GA4_ID=
# Google Ads: ID de conversion (empieza con AW-)
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Etiqueta de la conversion "click a WhatsApp" (lo que va despues de la barra
# en send_to: AW-XXXX/estaParte). Conversion tipo Contacto/Lead.
NEXT_PUBLIC_GADS_WA_LABEL=
